{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Discover Your Glow" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Curated skincare for luminous, everyday radiance." },
    { "type": "url", "id": "cta_url", "label": "CTA URL" },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Shop Best Sellers" }
  ],
  "presets": [{"name":"Hero"}]
}
{% endschema %}

<section class="hero-section" style="background-image: url({{ section.settings.image | img_url: '2048x' }}); background-size: cover; background-position:center;">
  <div class="hero-inner container" style="padding: 6rem 1rem; text-align:center;">
    <h1 class="hero-heading">{{ section.settings.heading }}</h1>
    <p class="hero-subheading">{{ section.settings.subheading }}</p>
    {% if section.settings.cta_url %}
      <a href="{{ section.settings.cta_url }}" class="btn btn-primary" style="background: var(--color-blush); color: #111; padding: .75rem 1.25rem; border-radius: 6px; display:inline-block; margin-top:1rem;">
        {{ section.settings.cta_text }}
      </a>
    {% endif %}
  </div>
</section>
