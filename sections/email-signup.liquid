{% schema %}
{
  "name": "Email Signup",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join & Save 10%" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Sign up to get exclusive launches and 10% off your first order." },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Get My 10% Off" },
    { "type": "checkbox", "id": "show_disclaimer", "label": "Show small privacy disclaimer", "default": true }
  ],
  "presets": [{"name":"Email Signup","category":"Form"}]
}
{% endschema %}

<section class="section email-signup" style="background:var(--color-cream); padding:2rem 1rem;">
  <div class="container" style="max-width:720px; margin:0 auto; text-align:center; padding:1.5rem;">
    <h3>{{ section.settings.heading }}</h3>
    {% if section.settings.subheading %}<p class="muted">{{ section.settings.subheading }}</p>{% endif %}

    {% form 'newsletter' %}
      <div class="newsletter-form" style="display:flex; gap:.5rem; justify-content:center; margin-top:1rem; flex-wrap:wrap;">
        <input type="email" name="contact[email]" placeholder="Email address" aria-label="Email address" required style="padding:.75rem 1rem; border-radius:6px; border:1px solid #e6e6e6; min-width:220px;" />
        <button type="submit" class="btn btn-primary" style="padding:.75rem 1.25rem; border-radius:6px; background:var(--color-blush); color:#111; border:none;">{{ section.settings.button_text }}</button>
      </div>
    {% endform %}

    {% if section.settings.show_disclaimer %}
      <p class="muted" style="font-size:.85rem; margin-top:.75rem;">By subscribing you agree to receive marketing emails. Unsubscribe anytime.</p>
    {% endif %}
  </div>
</section>
