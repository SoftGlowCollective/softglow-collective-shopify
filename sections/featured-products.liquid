{% schema %}
{
  "name": "Featured Products (Best Sellers)",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Collection (Best Sellers)" },
    { "type": "number", "id": "limit", "label": "Number of products", "min": 1, "max": 12, "default": 6 },
    { "type": "select", "id": "columns", "label": "Columns", "options": [{"value":"2","label":"2"},{"value":"3","label":"3"},{"value":"4","label":"4"}], "default":"3" },
    { "type": "text", "id": "heading", "label": "Section heading", "default": "Best Sellers" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Our most-loved picks 	6 curated for glow." }
  ],
  "blocks": [],
  "presets": [{"name":"Featured Products","category":"Products"}]
}
{% endschema %}

<section class="section featured-products">
  <div class="container" style="padding:2.5rem 1rem;">
    <div class="section-header" style="text-align:center; margin-bottom:1.25rem;">
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.subheading %}<p class="muted">{{ section.settings.subheading }}</p>{% endif %}
    </div>

    {% if section.settings.collection and collections[section.settings.collection] %}
      {% assign coll = collections[section.settings.collection] %}
      <div class="grid grid--{{ section.settings.columns }}" style="display:grid; gap:1rem; grid-template-columns: repeat({{ section.settings.columns }}, 1fr);">
        {% for product in coll.products limit: section.settings.limit %}
          <div class="grid__item">
            {% render 'product-card', product: product %}
          </div>
        {% endfor %}
      </div>
      {% if coll.products_count > section.settings.limit %}
        <div style="text-align:center; margin-top:1rem;">
          <a href="{{ coll.url }}" class="btn btn-secondary">View All</a>
        </div>
      {% endif %}
    {% else %}
      <p>No collection selected 	6 pick a collection in the section settings to show featured products.</p>
    {% endif %}
  </div>
</section>
